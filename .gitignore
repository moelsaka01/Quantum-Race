# Quantum Race - Git ignore rules

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Node / frontend
node_modules/
frontend/node_modules/
frontend/dist/
dist/
build/
.vite/
frontend/.vite/
.npm/
.pnpm-store/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage output
coverage/
frontend/coverage/
playwright-report/
test-results/

# Local databases / generated state
*.db
*.sqlite
*.sqlite3
*.db-journal
instance/

# Logs and runtime files
logs/
*.log
*.pid
*.seed
*.pid.lock

# Docker / local overrides
.docker/
docker-compose.override.yml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# Generated artifacts / local packaging
outputs/
work/
*.zip
*.tar.gz
*.tmp
